{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "src/app-api.ts",
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/platform/shared/**/*.ts",
    "src/platform/renderer/**/*.ts",
    "src/platform/renderer/**/*.tsx",
    "src/platform/ai-provider/shared/**/*.ts",
    "src/features/*/shared/**/*.ts",
    "src/features/*/renderer/**/*.ts",
    "src/features/*/renderer/**/*.tsx",
    "tests/**/*.tsx"
  ]
}
